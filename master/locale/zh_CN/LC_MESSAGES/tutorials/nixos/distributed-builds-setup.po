#: ../../../tutorials/nixos/distributed-builds-setup.md:173
msgid "NixOS"
msgstr ""

#: ../../../tutorials/nixos/distributed-builds-setup.md:175
msgid ""
"If your *local machine* runs NixOS, in its configuration directory create "
"the file `distributed-builds.nix`:"
msgstr ""

#: ../../../tutorials/nixos/distributed-builds-setup.md:177
msgid ""
"{ pkgs, ... }:\n"
"{\n"
"  nix.distributedBuilds = true;\n"
"  nix.settings.builders-use-substitutes = true;\n"
"\n"
"  nix.buildMachines = [\n"
"    {\n"
"      hostName = \"remotebuilder\";\n"
"      sshUser = \"remotebuild\";\n"
"      sshKey = \"/root/.ssh/remotebuild\";\n"
"      system = pkgs.stdenv.hostPlatform.system;\n"
"      supportedFeatures = [ \"nixos-test\" \"big-parallel\" \"kvm\" ];\n"
"    }\n"
"  ];\n"
"}"
