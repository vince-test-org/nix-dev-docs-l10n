#: ../../../guides/faq.md:88
msgid "How do I connect to any of the machines in NixOS tests?"
msgstr ""

#: ../../../guides/faq.md:90
msgid "Apply the following patch:"
msgstr ""

#: ../../../guides/faq.md:92
msgid ""
"diff --git a/nixos/lib/test-driver/test-driver.pl b/nixos/lib/test-driver/"
"test-driver.pl\n"
"index 8ad0d67..838fbdd 100644\n"
"--- a/nixos/lib/test-driver/test-driver.pl\n"
"+++ b/nixos/lib/test-driver/test-driver.pl\n"
"@@ -34,7 +34,7 @@ foreach my $vlan (split / /, $ENV{VLANS} || \"\") {\n"
"     if ($pid == 0) {\n"
"         dup2(fileno($pty->slave), 0);\n"
"         dup2(fileno($stdoutW), 1);\n"
"-        exec \"vde_switch -s $socket\" or _exit(1);\n"
"+        exec \"vde_switch -tap tap0 -s $socket\" or _exit(1);\n"
"     }\n"
"     close $stdoutW;\n"
"     print $pty \"version\\n\";\n"
msgstr ""

#: ../../../guides/faq.md:108
msgid "And then the vde_switch network should be accessible locally."
msgstr ""

