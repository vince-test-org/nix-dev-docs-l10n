msgstr ""

#: ../../../install-nix.md:26
msgid "$ curl -L https://nixos.org/nix/install | sh\n"
msgstr ""

#: ../../../install-nix.md:31
msgid "**Updating to macOS 15 Sequoia**"
msgstr ""

#: ../../../install-nix.md:33
msgid "If you recently updated to macOS 15 Sequoia and are getting the error"
msgstr ""

#: ../../../install-nix.md:34
