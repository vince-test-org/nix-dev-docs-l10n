#: ../../../install-nix.md:0
msgid "Windows (WSL2)"
msgstr ""

#: ../../../install-nix.md:44
msgid "Install Nix via the recommended [single-user installation]:"
msgstr ""

#: ../../../install-nix.md:46
msgid "$ curl -L https://nixos.org/nix/install | sh -s -- --no-daemon\n"
msgstr ""

#: ../../../install-nix.md:50
msgid ""
"However, if you have [systemd support] enabled, install Nix via the "
"recommended [multi-user installation]:"
msgstr ""

#: ../../../install-nix.md:0
msgid "Docker"
msgstr ""

#: ../../../install-nix.md:62
msgid "Start a Docker shell with Nix:"
msgstr ""

#: ../../../install-nix.md:64
msgid "$ docker run -it nixos/nix\n"
msgstr ""

#: ../../../install-nix.md:68
msgid "Or start a Docker shell with Nix exposing a `workdir` directory:"
msgstr ""

#: ../../../install-nix.md:70
msgid ""
"$ mkdir workdir\n"
"$ docker run -it -v $(pwd)/workdir:/workdir nixos/nix\n"
msgstr ""

#: ../../../install-nix.md:75
msgid ""
"The `workdir` example from above can also be used to start hacking on "
"Nixpkgs:"
msgstr ""

#: ../../../install-nix.md:77
msgid ""
"$ git clone git@github.com:NixOS/nixpkgs\n"
"$ docker run -it -v $(pwd)/nixpkgs:/nixpkgs nixos/nix\n"
"bash-5.1# nix-build -I nixpkgs=/nixpkgs -A hello\n"
"bash-5.1# find ./result # this symlink points to the build package\n"
msgstr ""

#: ../../../install-nix.md:87
msgid "Verify installation"
msgstr ""

#: ../../../install-nix.md:89
msgid "Check the installation by opening **a new terminal** and typing:"
msgstr ""

#: ../../../install-nix.md:91
msgid ""
"$ nix --version\n"
"nix (Nix) 2.11.0\n"
msgstr ""
